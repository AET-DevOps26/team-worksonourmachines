{
  "realm": "tutormatch",
  "displayName": "TUtorMatch",
  "enabled": true,
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "student",
        "description": "Learner role for TUtorMatch students."
      },
      {
        "name": "tutor",
        "description": "Teaching role for TUtorMatch tutors."
      },
      {
        "name": "admin",
        "description": "Administrative role for local TUtorMatch development."
      },
      {
        "name": "service",
        "description": "Internal service-to-service role, assigned to service accounts."
      }
    ]
  },
  "groups": [
    {
      "name": "students",
      "realmRoles": [
        "student"
      ]
    },
    {
      "name": "tutors",
      "realmRoles": [
        "tutor"
      ]
    },
    {
      "name": "admins",
      "realmRoles": [
        "admin"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "description": "OpenID Connect scope for realm roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "${rolesScopeConsentText}"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "realm_roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "client-web",
      "name": "TUtorMatch React Router BFF",
      "description": "Local development OIDC client for the web backend-for-frontend.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "$(KEYCLOAK_CLIENT_WEB_SECRET)",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "https://$(APP_HOSTNAME)/*"
      ],
      "webOrigins": [
        "https://$(APP_HOSTNAME)"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "basic",
        "email"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "https://$(APP_HOSTNAME)/*"
      }
    },
    {
      "clientId": "server-marketplace-admin",
      "name": "TUtorMatch Marketplace Admin API",
      "description": "Service account for marketplace backend to assign realm roles via Admin API.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "$(KEYCLOAK_SERVER_MARKETPLACE_ADMIN_SECRET)",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false
    },
    {
      "clientId": "tutormatch-dev-cli",
      "name": "TUtorMatch Dev CLI",
      "description": "Local-only public client for requesting test tokens with dummy users.",
      "enabled": "$${javascript: env.KEYCLOAK_DEV_CLI_ENABLED === 'true'}",
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocolMappers": [
        {
          "name": "server-ai-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "server-ai",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "server-ai",
      "name": "TUtorMatch AI Service",
      "description": "Service account for the AI backend; authenticates with client credentials to read student and marketplace data.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "$(AI_CLIENT_SECRET)",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": [
        "profile",
        "roles",
        "basic",
        "email"
      ],
      "attributes": {}
    },
    {
      "clientId": "server-student",
      "name": "TUtorMatch Student Service",
      "description": "Service account for the student backend; authenticates with client credentials when calling the AI service.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "$(KEYCLOAK_SERVER_STUDENT_SECRET)",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": [
        "profile",
        "roles",
        "basic",
        "email"
      ],
      "attributes": {}
    },
    {
      "id": "d8854ec4-8e9d-4d35-a111-776bf1dbe001",
      "clientId": "scalar-dev",
      "name": "Scalar Dev API Client",
      "description": "Local development client for Scalar API testing.",
      "rootUrl": "",
      "adminUrl": "",
      "baseUrl": "",
      "surrogateAuthRequired": false,
      "enabled": "$${javascript: env.KEYCLOAK_SCALAR_DEV_ENABLED === 'true'}",
      "alwaysDisplayInConsole": false,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "https://api.$(APP_HOSTNAME)",
        "https://api.$(APP_HOSTNAME)/"
      ],
      "webOrigins": [
        "https://api.$(APP_HOSTNAME)",
        "https://api.$(APP_HOSTNAME)/"
      ],
      "notBefore": 0,
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "publicClient": true,
      "frontchannelLogout": false,
      "protocol": "openid-connect",
      "attributes": {
        "id.token.as.detached.signature": "false",
        "logout.confirmation.enabled": "false",
        "client.introspection.response.allow.jwt.claim.enabled": "false",
        "oauth2.jwt.authorization.grant.enabled": "false",
        "standard.token.exchange.enabled": "false",
        "oauth2.device.authorization.grant.enabled": "false",
        "use.jwks.url": "false",
        "backchannel.logout.revoke.offline.tokens": "false",
        "use.refresh.tokens": "true",
        "realm_client": "false",
        "oidc.ciba.grant.enabled": "false",
        "client.use.lightweight.access.token.enabled": "false",
        "backchannel.logout.session.required": "true",
        "client_credentials.use_refresh_token": "false",
        "request.object.required": "not required",
        "access.token.header.type.rfc9068": "false",
        "acr.loa.map": "{}",
        "require.pushed.authorization.requests": "false",
        "tls.client.certificate.bound.access.tokens": "false",
        "display.on.consent.screen": "false",
        "token.response.type.bearer.lower-case": "false",
        "dpop.bound.access.tokens": "false"
      },
      "authenticationFlowBindingOverrides": {},
      "fullScopeAllowed": true,
      "nodeReRegistrationTimeout": -1,
      "defaultClientScopes": [
        "profile",
        "roles",
        "basic",
        "email"
      ],
      "optionalClientScopes": [],
      "protocolMappers": [
        {
          "name": "server-ai audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "server-ai",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "account audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "account",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
