{
    "name": "client-web",
    "version": "1.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "format": "biome format --write",
        "lint": "pnpm run lint:code && pnpm run lint:deps && pnpm run lint:unused && pnpm run lint:types",
        "lint:code": "biome check --diagnostic-level=warn",
        "lint:code:fix": "biome check --diagnostic-level=warn --write",
        "lint:deps": "depcruise app --config .dependency-cruiser.cjs",
        "lint:deps:test": "node scripts/test-dependency-cruiser.mjs",
        "lint:unused": "knip",
        "lint:types": "pnpm run typegen && tsc --noEmit",
        "dev": "react-router dev",
        "build": "react-router build",
        "typegen": "react-router typegen",
        "start": "react-router-serve ./build/server/index.js",
        "test": "echo 'No tests yet'"
    },
    "keywords": [],
    "author": "worksounourmachine",
    "packageManager": "pnpm@10.28.2",
    "dependencies": {
        "@base-ui/react": "^1.6.0",
