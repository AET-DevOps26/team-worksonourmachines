        "@hugeicons/react": "^1.1.7",
        "@react-router/node": "^7.15.1",
        "@react-router/serve": "^7.15.1",
        "@tailwindcss/vite": "^4.3.0",
        "arktype": "^2.2.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cookie": "^1.0.2",
        "isbot": "^5.1.40",
        "openid-client": "^6.8.1",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-router": "^7.15.1",
        "redis": "^4.7.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "winston": "^3.19.0"
    },
