{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "entry": ["app/routes/**/*.{ts,tsx}"],
    "project": ["app/**/*.{ts,tsx}"],
    "ignore": [
        "app/.server/api/*/generated/**",
        // todo remove app/.server as soon as apis are used
        "app/.server/**"
    ],
    "ignoreDependencies": ["tailwindcss"],
    "ignoreUnresolved": ["tslib"]
}
