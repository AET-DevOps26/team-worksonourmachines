{$APP_HOSTNAME} {
	handle /stomp* {
		reverse_proxy server-communication:8083 {
			transport http {
				versions 1.1
			}
		}
	}

	handle {
		reverse_proxy client-web:3000
	}
}

auth.{$APP_HOSTNAME} {
	reverse_proxy keycloak:8080
}

grafana.{$APP_HOSTNAME} {
	reverse_proxy grafana:3000
}

api.{$APP_HOSTNAME} {
	reverse_proxy api-ui:8080
}
