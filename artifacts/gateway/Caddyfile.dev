{
	local_certs
	servers {
		protocols h1
	}
}

{$APP_HOSTNAME} {
	tls internal

	handle /stomp* {
		reverse_proxy server-communication:8083 {
			transport http {
				versions 1.1
			}
		}
	}

	handle {
		reverse_proxy client-web:5173
	}
}

auth.{$APP_HOSTNAME} {
	tls internal
	reverse_proxy keycloak:8080
}

grafana.{$APP_HOSTNAME} {
	tls internal
	reverse_proxy grafana:3000
}

prometheus.{$APP_HOSTNAME} {
	tls internal
	reverse_proxy prometheus:9090
}

api.{$APP_HOSTNAME} {
	tls internal

	handle /v1/students* {
		reverse_proxy server-student:8081
	}

	handle /v1/admin* {
		reverse_proxy server-marketplace:8082
	}

	handle /v1/modules* {
		reverse_proxy server-marketplace:8082
	}

	handle /v1/tutors* {
		reverse_proxy server-marketplace:8082
	}

	handle /v1/tutor-applications* {
		reverse_proxy server-marketplace:8082
	}

	handle /v1/conversations* {
		reverse_proxy server-communication:8083
	}

	handle /v1/plan* {
		reverse_proxy ai:8000
	}

	handle {
		reverse_proxy api-ui:8080
	}
}
