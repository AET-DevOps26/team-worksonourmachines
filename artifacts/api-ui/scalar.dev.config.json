        }
      },
      "KeycloakAdminAuth": {
        "flows": {
          "authorizationCode": {
            "x-scalar-client-id": "scalar-dev",
            "x-scalar-redirect-uri": "https://api.tutormatch.localhost",
            "x-usePkce": "SHA-256",
            "selectedScopes": ["openid", "basic", "profile", "email", "roles"]
          }
        }
      }
    }
  },
  "persistAuth": true
}
