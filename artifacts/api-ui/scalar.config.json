{
  "metaData": {
    "title": "TutorMatch API Reference",
    "description": "OpenAPI specifications for TutorMatch services"
  },
  "hideTestRequestButton": false,
  "hideClientButton": false,
  "authentication": {
    "preferredSecurityScheme": "KeycloakBearerAuth",
