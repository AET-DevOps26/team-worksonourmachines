# Dependencies & package-manager caches
**/node_modules
**/.pnpm-store

# Build / toolchain outputs
**/build
**/dist
**/target
**/.vite
**/.cache
**/.react-router
**/*.tsbuildinfo
**/.gradle
**/.pytest_cache
**/.ruff_cache
**/.make

# VCS / IDE / OS / local env
.git
.gitignore
**/.DS_Store
**/.idea
**/.vscode
**/.env
**/.venv

# Logs / temp
**/pnpm-debug.log
**/*.log
**/*.tmp

# Docs (not used by image builds)
**/*.md
docs/

# Python bytecode
**/__pycache__
**/*.pyc
**/*.pyo

# Infra local state (not used by app image builds)
**/.terraform
*.tfstate
*.tfstate.*

# Dockerfiles are not needed inside app layers
Dockerfile
