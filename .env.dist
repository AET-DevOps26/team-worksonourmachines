# Keyclock Credentials
KEYCLOAK_DB_PASSWORD=
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_CLIENT_SECRET=
SERVER_STUDENT_CLIENT_SECRET=
KEYCLOAK_SERVER_MARKETPLACE_ADMIN_SECRET=
AI_CLIENT_SECRET=

# Postgres Credentials
POSTGRES_PASSWORD=

# Grafana Alerting (placeholders are fine for local k3d; use real SMTP for Rancher)
GRAFANA_SMTP_USER=noreply@localhost
GRAFANA_SMTP_PASSWORD=changeme

# Grafana Dashboard Admin (local defaults; override for production)
GRAFANA_ADMIN_USER=admin.tutormatch@example.com
GRAFANA_ADMIN_PASSWORD=adminpassword123

# ⚠️  Only ONE of the three LLM blocks below should be uncommented at a time.
#     If multiple blocks are active, the last one wins — which may not be what you expect.
# PRODUCTION IS RUN ONLY WITH LOGOS.

# Ollama (default) — runs automatically via docker compose
COMPOSE_PROFILES=ollama
LLM_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.2:latest

# LM Studio — uncomment and comment out the ollama block above
# COMPOSE_PROFILES=
# LLM_PROVIDER=lmstudio
# LLM_BASE_URL=http://host.docker.internal:1234/v1
# LLM_MODEL=local-model

# Logos (cloud) — uncomment and comment out the ollama block above
# COMPOSE_PROFILES=
# LLM_PROVIDER=logos
# LLM_BASE_URL=https://logos.aet.cit.tum.de/v1
# LLM_MODEL=openai/gpt-oss-120b
# LLM_API_KEY=lg-...
