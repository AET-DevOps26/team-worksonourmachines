# DO NOT commit a real secrets.yml — this is a template only.
# Create the secret manually:
#
#   kubectl create secret generic ai-secrets \
#     --from-literal=OPENAI_API_KEY=sk-... \
#     -n tutormatch
#
# Or apply this file after filling in the base64-encoded value:
#   echo -n "sk-..." | base64

apiVersion: v1
kind: Secret
metadata:
  name: ai-secrets
  namespace: tutormatch
type: Opaque
data:
  OPENAI_API_KEY: <base64-encoded-value>
